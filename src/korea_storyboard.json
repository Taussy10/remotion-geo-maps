  "captions": [
    {
      "text": "Why are there 2 Koreas? 🇰🇷🇰🇵",
      "fadeIn": [0, 20],
      "fadeOut": [80, 90],
      "style": {
        "bottom": 250,
        "background": "rgba(0,0,0,0.55)",
        "border": "1px solid rgba(255,255,255,0.12)",
        "padding": "10px 32px"
